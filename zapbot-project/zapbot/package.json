{
  "name": "zapbot",
  "version": "0.1.0",
  "private": true,
  "description": "No-code WhatsApp chatbot builder for Brazilian SMBs",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "pnpm --filter @zapbot/db migrate",
    "db:generate": "pnpm --filter @zapbot/db generate",
    "db:studio": "pnpm --filter @zapbot/db studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
